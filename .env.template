# ============================================================================
# 临床试验订阅与翻译系统 - 环境变量模板
# ============================================================================
# 使用说明：
# 1. 复制此文件为 .env：cp .env.template .env
# 2. 填写实际的 API 密钥和配置
# 3. 所有配置项都有默认值，未配置时将使用默认值
# ============================================================================


# ==================== 1. 翻译模型配置 ====================
# 多模型 fallback 链：按顺序尝试，第一个成功即返回
# 详细配置见 config.yaml 的 translate_models 段
# 支持 OpenAI 兼容 API (qwen/glm/stepfun/gemini/openai)

# 主力模型：通义千问 (支持多 key，逗号分隔自动轮换)
QWEN_API_KEY=your_qwen_api_key_here

# 备选模型 1：智谱 GLM
ZHIPU_API_KEY=your_zhipu_api_key_here

# 备选模型 2：阶跃星辰
STEP_API_KEY=your_step_api_key_here

# 备选模型 3：Gemini (经 ai-proxy.chatwise.app 走 OpenAI 兼容协议)
GEMINI_API_KEY=your_gemini_api_key_here

# 备选模型 4：OpenAI (可选，当前未配置)
# OPENAI_API_KEY=your_openai_api_key_here

# [DEPRECATED] 旧版配置（保留向后兼容，新配置优先使用上面的大写变量）
LLM_PROVIDER=zhipu
zhipu_api_key=your_zhipu_api_key_here
zhipu_base_url=https://open.bigmodel.cn/api/paas/v4
zhipu_model_name=glm-4.5-air
gemini_api_key=your_gemini_api_key_here
gemini_base_url=https://ai-proxy.chatwise.app/generativelanguage/v1beta/models
gemini_model_name=gemini-3-flash-preview
qwen_base_url=https://dashscope.aliyuncs.com/compatible-mode/v1
qwen_api_key=your_qwen_api_key_here
qwen_default_model=qwen3.6-flash


# ==================== 2. 推送渠道配置 ====================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- 微信公众号 (预留，当前未使用) ---
WECHAT_APP_ID=your_wechat_app_id_here
WECHAT_APP_SECRET=your_wechat_app_secret_here
WECHAT_NICKNAME=your_wechat_nickname_here

# --- GeWe 个人微信群推送 ---
# 总开关：false 时跳过微信推送；缺少 APP_ID/TOKEN/WXID 时也会自动跳过
GEWE_ENABLED=false
GEWE_API_HOST=api.geweapi.com
GEWE_APP_ID=your_gewe_app_id_here
GEWE_TOKEN=your_gewe_token_here
# 目标群（支持 JSON 数组或逗号分隔）
GEWE_TO_WXID=["group1@chatroom","group2@chatroom"]
# 卡片模式：true=额外发可跳转卡片；false=仅纯文字
GEWE_CARD_MODE=false
# 单条消息长度上限（分批用，默认 500 避免微信折叠）
GEWE_MSG_MAX_LEN=500
GEWE_PUSH_RETRY_TIMES=3
GEWE_PUSH_RETRY_DELAY=5

# --- 飞书 ---
FEISHU_APP_ID=your_feishu_app_id_here
FEISHU_APP_SECRET=your_feishu_app_secret_here
# 多群 ID（逗号分隔）
FEISHU_CHAT_IDS=chat_id_1,chat_id_2


# ==================== 3. FastGPT 知识库同步配置 ====================

# FastGPT 实例
FASTGPT_BASE_URL=https://your-fastgpt-domain.com/api
FASTGPT_API_KEY=your_fastgpt_api_key_here
FASTGPT_DATASET_ID=your_dataset_id_here

# 调度器
FASTGPT_ENABLE_SCHEDULER=true
FASTGPT_TIMEZONE=Asia/Shanghai
FASTGPT_DAILY_SYNC_TIME=02:00

# 本地文档扫描
# 根目录（支持 JSON 数组或逗号分隔）
FASTGPT_LOCAL_DIR=["/path/to/output/dir1","/path/to/output/dir2"]
# 中文文档子目录名
FASTGPT_CN_SUBDIR=cn
# 支持的文件扩展名
FASTGPT_FILE_EXTENSIONS=.pdf,.md,.txt,.json,.docx,.html
# 忽略的文件/目录（正则表达式）
FASTGPT_IGNORE_PATTERNS=^\..*,.*\.tmp$,__pycache__

# 文本分块
FASTGPT_CHUNK_SIZE=1500
FASTGPT_CHUNK_SPLIT_MODE=size

# 同步状态
FASTGPT_SYNC_STATE_DB=./data/fastgpt_sync_state.json

# 推送重试
FASTGPT_PUSH_RETRY_TIMES=3
FASTGPT_PUSH_RETRY_DELAY_SECONDS=5


# ==================== 4. 搜索参数配置 ====================

SEARCH_CONDITION=Pancreatic Cancer
KEYWORDS=KRAS,Immune,Immunotherapy,TP53,ATM,免疫
DAYS_BACK=30


# ==================== 5. 邮件配置 ====================

EMAIL_RECIPIENT=your_email@example.com
